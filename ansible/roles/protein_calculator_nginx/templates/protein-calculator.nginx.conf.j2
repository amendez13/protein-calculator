server {
  listen {{ protein_calculator_nginx_listen_port }};
  server_name {{ protein_calculator_nginx_server_name }};

  location / {
    proxy_pass http://{{ protein_calculator_nginx_upstream_host }}:{{ protein_calculator_nginx_upstream_port }};
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }
}
